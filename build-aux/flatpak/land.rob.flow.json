{
  "app-id": "land.rob.flow",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "flow",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "flow",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 flow.py /app/bin/flow",
        "install -Dm644 data/land.rob.flow.desktop /app/share/applications/land.rob.flow.desktop",
        "install -Dm644 data/land.rob.flow.svg /app/share/icons/hicolor/scalable/apps/land.rob.flow.svg",
        "install -Dm644 data/land.rob.flow.metainfo.xml /app/share/metainfo/land.rob.flow.metainfo.xml"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../.."
        }
      ]
    }
  ]
}
