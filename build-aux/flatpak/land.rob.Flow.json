{
  "app-id": "land.rob.Flow",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "flowfree",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "flowfree",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 flowfree.py /app/bin/flowfree",
        "install -Dm644 data/land.rob.Flow.desktop /app/share/applications/land.rob.Flow.desktop",
        "install -Dm644 data/land.rob.Flow.svg /app/share/icons/hicolor/scalable/apps/land.rob.Flow.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../.."
        }
      ]
    }
  ]
}
